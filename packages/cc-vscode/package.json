{
  "name": "cc-vscode",
  "displayName": "Claude Code",
  "version": "0.1.0",
  "description": "AI-powered coding assistant powered by Claude Code",
  "publisher": "cc-vscode",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:cc-vscode.openChat",
    "onCommand:cc-vscode.newSession"
  ],
  "main": "dist/extension.js",
  "files": [
    "dist/",
    "bridge-dist/",
    "webview-ui/dist/"
  ],
  "contributes": {
    "configuration": {
      "title": "Claude Code",
      "properties": {
        "claudeCode.baseUrl": {
          "type": "string",
          "default": "",
          "description": "API base URL (ANTHROPIC_BASE_URL)"
        },
        "claudeCode.authToken": {
          "type": "string",
          "default": "",
          "description": "API auth token (ANTHROPIC_AUTH_TOKEN)"
        },
        "claudeCode.model": {
          "type": "string",
          "default": "",
          "description": "Default model (ANTHROPIC_MODEL)"
        },
        "claudeCode.defaultOpusModel": {
          "type": "string",
          "default": "",
          "description": "Default Opus model (ANTHROPIC_DEFAULT_OPUS_MODEL)"
        },
        "claudeCode.defaultSonnetModel": {
          "type": "string",
          "default": "",
          "description": "Default Sonnet model (ANTHROPIC_DEFAULT_SONNET_MODEL)"
        },
        "claudeCode.defaultHaikuModel": {
          "type": "string",
          "default": "",
          "description": "Default Haiku model (ANTHROPIC_DEFAULT_HAIKU_MODEL)"
        },
        "claudeCode.subagentModel": {
          "type": "string",
          "default": "",
          "description": "Subagent model (CLAUDE_CODE_SUBAGENT_MODEL)"
        },
        "claudeCode.effortLevel": {
          "type": "string",
          "default": "",
          "description": "Effort level (CLAUDE_CODE_EFFORT_LEVEL)"
        },
        "claudeCode.extraEnv": {
          "type": "object",
          "default": {},
          "description": "Additional environment variables for the Claude Code bridge"
        }
      }
    },
    "commands": [
      {
        "command": "cc-vscode.openChat",
        "title": "Claude Code: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cc-vscode.newSession",
        "title": "Claude Code: New Session"
      },
      {
        "command": "cc-vscode.stopBridge",
        "title": "Claude Code: Stop Bridge Server"
      },
      {
        "command": "cc-vscode.restartBridge",
        "title": "Claude Code: Restart Bridge Server"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "cc-vscode.openChat" },
        { "command": "cc-vscode.newSession" },
        { "command": "cc-vscode.stopBridge" },
        { "command": "cc-vscode.restartBridge" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile && npm run build:webview && bash scripts/copy-bridge.sh",
    "build:webview": "cd webview-ui && npx vite build",
    "copy-bridge": "bash scripts/copy-bridge.sh",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
